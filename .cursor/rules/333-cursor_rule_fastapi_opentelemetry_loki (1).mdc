# main.py FastAPI

No `main.py`, respeitar esta ordem:

```python
import logging

from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse
from opentelemetry import trace

from core.config import settings
from core.logging_config import RequestLoggingMiddleware, setup_logging
from core.telemetry import (
    instrument_fastapi,
    instrument_sqlalchemy,
    log_telemetry_status,
    setup_base_telemetry,
    setup_logging_instrumentation,
)


# Ordem da observabilidade:
# 1) tracer provider/exporter (define service.name no resource)
# 2) instrumentar logging (captura service.name e injeta trace_id/span_id)
# 3) dictConfig (handlers stdout + Loki)
# 4) logar o status já formatado.
setup_base_telemetry()
setup_logging_instrumentation()
setup_logging()

logger = logging.getLogger(settings.service_name)
log_telemetry_status()

app = FastAPI(title=settings.OTEL_SERVICE_NAME)
app.add_middleware(RequestLoggingMiddleware)

instrument_fastapi(app)
# instrument_sqlalchemy(engine)  # se o projeto usar SQLAlchemy


@app.exception_handler(Exception)
async def global_exception_handler(request: Request, exc: Exception):
    logger.exception(
        "Erro não tratado na rota %s %s",
        request.method,
        request.url.path,
    )

    return JSONResponse(
        status_code=500,
        content={"detail": "Erro interno do servidor"},
    )


if settings.ENABLE_TEST_ROUTES:

    @app.get("/teste-erro-loki")
    def teste_erro_loki():
        raise Exception("Teste de erro para Loki")

    @app.get("/telemetry-test")
    def telemetry_test():
        tracer = trace.get_tracer(__name__)

        with tracer.start_as_current_span("teste-manual-opentelemetry") as span:
            span.set_attribute("app.name", settings.service_name)
            span.set_attribute("test.type", "manual")

            return {
                "status": "ok",
                "message": "Trace manual gerado",
            }
```

Se o projeto já possui `app = FastAPI(...)`, não criar outro app. Adaptar o existente.

Se usar routers, manter os `include_router` existentes.

